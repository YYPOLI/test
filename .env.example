# PermitGuard API Configuration
# Copy this file to .env and fill in your actual keys

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Alibaba Qwen
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://coding.dashscope.aliyuncs.com/v1

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI-compatible (GPT)
GPT_API_KEY=your_gpt_api_key_here
GPT_BASE_URL=https://api.aiearth.dev/v1

# Data paths
BASE_DATA_PATH=E:/Dataset/Phishing/
