# PermitGuard API Configuration
# Copy this file to .env and fill in your actual keys

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Alibaba Qwen
QWEN_API_KEY=your_qwen_api_key_here
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI-compatible (GPT)
GPT_API_KEY=your_gpt_api_key_here
GPT_BASE_URL=https://api.openai.com/v1

# Data paths (optional, only if using an external full dataset)
# BASE_DATA_PATH=/path/to/your/full/dataset/

# Google Cloud Platform (only needed for pipeline/bigquery_extraction)
# Required: a GCP project with BigQuery API enabled.
# Authenticate locally with `gcloud auth application-default login`
# OR set GOOGLE_APPLICATION_CREDENTIALS to a service-account JSON path.
GCP_PROJECT_ID=your_gcp_project_id_here

# Etherscan API (needed for pipeline/data_processing/spender_history_crawler)
# Free tier: 5 calls/sec. Register at https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here

# Ethereum RPC (needed for pipeline/feature_engineering token queries, optional)
# Defaults to public endpoint if not set.
# ETH_RPC_URL=https://mainnet.infura.io/v3/your_project_id

# Optional proxy (only if your network requires it for Gemini / GCP)
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
