# Environment & Secrets
.env
*.key

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Data files (too large for git)
*.csv
*.json
*.jsonl
!data/**/*.csv
!data/**/*.json
