# Environment & Secrets
.env
*.key

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
*.egg

# Data files (too large for git)
*.csv
*.json
*.jsonl
!data/**/*.csv
!data/**/*.json
# Pipeline-generated data (can be very large, rebuild with pipeline/ scripts)
data/pipeline_output/
!data/pipeline_output/.gitkeep

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini
*.downloading

# Jupyter
.ipynb_checkpoints/

# Result outputs (generated at runtime, keep .gitkeep for directory structure)
result/reports/*.json
result/error_analysis/*.json
result/figures/*.png
result/figures/*.pdf
!result/**/.gitkeep
output/
