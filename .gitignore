.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
desktop.ini
*.downloading

# Jupyter
.ipynb_checkpoints/

# Result outputs (generated at runtime, keep .gitkeep for directory structure)
result/reports/*.json
result/error_analysis/*.json
result/figures/*.png
result/figures/*.pdf
!result/**/.gitkeep
output/

